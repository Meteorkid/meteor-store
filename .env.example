# ========================================
# 国内支付 - 支付宝
# ========================================
# 从支付宝开放平台获取: https://open.alipay.com
ALIPAY_APP_ID=your_app_id_here
ALIPAY_PRIVATE_KEY=your_private_key_here
ALIPAY_PUBLIC_KEY=your_alipay_public_key_here
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_SELLER_ID=your_seller_id_here

# ========================================
# 国内支付 - 微信支付
# ========================================
# 从微信商户平台获取: https://pay.weixin.qq.com
WECHAT_APP_ID=your_app_id_here
WECHAT_MCH_ID=your_mch_id_here
WECHAT_API_KEY=your_api_key_here
WECHAT_API_V3_KEY=your_api_v3_key_here
WECHAT_CERT_PATH=your_cert_path_here

# ========================================
# 通用配置
# ========================================
# Site URL (for redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ========================================
# 数据库 - Neon PostgreSQL
# ========================================
# 从 Neon 控制台获取: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ========================================
# 邮件 - Resend
# ========================================
# 从 Resend 控制台获取: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# 发件人邮箱（需在 Resend 中验证域名）
RESEND_FROM_EMAIL=noreply@yourdomain.com
