# ==========================================
# 环境变量配置
# ==========================================

# ---------- Database (Neon PostgreSQL) ----------
# 从 Neon 控制台获取: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ---------- Alipay (支付宝) ----------
# 沙箱环境: https://open.alipay.com/develop/sandbox
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
# 沙箱: https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 正式: https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_SELLER_ID=

# ---------- Email (Resend) ----------
# 注册: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_AUDIENCE_ID=

# ---------- Delivery Retry ----------
# 用于手动触发邮件补发的 API token
DELIVERY_RETRY_SECRET=

# ---------- Site ----------
# 本地开发: http://localhost:3000
# 生产环境: https://www.imagentx.top
NEXT_PUBLIC_SITE_URL=http://localhost:3000
